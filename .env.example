# Absolute path to the FC_Sales_Analyzer skill directory.
# OPTIONAL in production — lib/skill-loader.ts falls back to the
# bundled skill/ directory at the repo root when SKILL_PATH is unset,
# so Railway deploys don't need this set. Set it locally if you're
# iterating on the skill files outside the repo.
# Use forward slashes — Node accepts them on Windows.
SKILL_PATH=C:/Users/kaial/Desktop/FC_Sales_Analyzer

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# OpenAI API key — https://platform.openai.com/api-keys
# Used for Whisper audio transcription via lib/openai.ts.
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# Clerk user id seeded as the platform super admin (prisma/seed.ts).
# If unset, the seed falls back to the hardcoded Kai id baked into
# the script. Set this in dev environments where you want to seed a
# different account as super admin.
# SUPER_ADMIN_USER_ID=user_xxx

# Clerk user id of the IRREVOCABLE seed super admin — the only
# account allowed to delete OTHER super admins
# (lib/super-admin.ts#canDeleteSuperAdmin reads this). In production
# this should match SUPER_ADMIN_USER_ID. Hardcoded to Kai's id by
# default; override only when standing up a separate deployment with
# a different root-of-trust account.
# SUPER_ADMIN_SEED_ID=user_xxx

# Optional: explicit path to the ffmpeg binary used by
# lib/audio-chunker.ts to split recordings >25MB before sending to
# Whisper. If unset, the chunker falls back to "ffmpeg" on PATH and
# then to a hardcoded Windows install location. Set this on any
# machine where ffmpeg lives at a known custom location.
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
